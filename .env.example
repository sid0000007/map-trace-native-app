# Base URL of the locations API (Cloudflare Worker).
# Read by src/lib/config/env.ts.
#
# The app DEFAULTS to the deployed Worker, so you don't need to set this to run
# against production. Set it only to point at a local `wrangler dev` instance:
#
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:8787
#
# Deployed (default): https://draftbit-locations-api.siddharth11tha.workers.dev
