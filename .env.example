# Base URL of the locations API (Cloudflare Worker).
# Read by src/lib/config/env.ts. Must be prefixed EXPO_PUBLIC_ to be exposed to the client.
# Local development (wrangler dev) defaults to http://localhost:8787 if unset.
# Phase 5 sets this to the deployed Worker URL.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787
